# Environment variables for Portfolio Manager

# Application Settings
APP_NAME=Portfolio Manager API
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=portfolio_db
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@db:5432/portfolio_db

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080,http://localhost:80

# Docker Registry (for CI/CD)
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=your-username/portfolio-manager
DOCKER_IMAGE_TAG=latest

# AWS Configuration (for EC2 deployment)
AWS_REGION=us-east-1
EC2_INSTANCE_ID=
EC2_KEY_PATH=
EC2_USER=ec2-user
EC2_HOST=
SSH_KEY_PATH=

# GitHub Configuration
GITHUB_TOKEN=
GITHUB_REPO=your-username/portfolio-manager
GITHUB_BRANCH=main

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ADMIN_EMAIL=admin@example.com

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups
